---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import TrustBar from '../components/TrustBar.astro';
import WhySection from '../components/WhySection.astro';
import AiSection from '../components/AiSection.astro';
import ForSection from '../components/ForSection.astro';
import OpportunitySection from '../components/OpportunitySection.astro';
import AcquisitionSection from '../components/AcquisitionSection.astro';
import FaqSection from '../components/FaqSection.astro';
import ClosingCTA from '../components/ClosingCTA.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout>
  <Nav />
  <main>
    <Hero />
    <TrustBar />
    <WhySection />
    <AiSection />
    <ForSection />
    <OpportunitySection />
    <AcquisitionSection />
    <FaqSection />
    <ClosingCTA />
    <Footer />
  </main>
  <script>
    // Navbar scroll effect
    (function () {
      const nav = document.getElementById('nav');
      if (!nav) return;
      window.addEventListener('scroll', () => {
        if (window.scrollY > 80) {
          nav.classList.add('nav-scrolled', 'shadow-xl');
        } else {
          nav.classList.remove('nav-scrolled', 'shadow-xl');
        }
      });
    })();

    // Keyboard shortcuts
    (function () {
      document.addEventListener('keydown', (e) => {
        if (e.key === '/' && document.activeElement?.tagName === 'BODY') {
          e.preventDefault();
          document.getElementById('acquire')?.scrollIntoView({ behavior: 'smooth', block: 'center' });
        }
      });

      let keys = '';
      document.addEventListener('keypress', (e) => {
        keys += e.key.toLowerCase();
        if (keys.length > 10) keys = keys.slice(-10);
        if (keys.includes('cloud') || keys.includes('edesigr')) {
          document.getElementById('acquire')?.scrollIntoView({ behavior: 'smooth', block: 'center' });
          keys = '';
        }
      });
    })();

    // Card entrance animation
    (function () {
      const cards = document.querySelectorAll('.premium-card');
      cards.forEach((card, index) => {
        card.style.opacity = '0';
        card.style.transform = 'translateY(15px)';
        setTimeout(() => {
          card.style.transition = 'all 0.5s cubic-bezier(0.34, 1.56, 0.64, 1)';
          card.style.transitionDelay = (index * 80) + 'ms';
          card.style.opacity = '1';
          card.style.transform = 'translateY(0)';
        }, 180);
      });
    })();
  </script>
</BaseLayout>
